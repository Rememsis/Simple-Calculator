# ask user to input two numbers and an operation, then perform the operation and print the result
a = int(input("Enter the first number: "))
sign = input("Enter the operation: ").lower().strip()
b = int(input("Enter the second number: "))

# ask user to confirm the operation before performing it
comfirm = input(f"Confirm: {a} {sign} {b} (yes/no): ")

# perform the operation if the user confirms, otherwise cancel the operation
if comfirm.lower() == "no" or comfirm.lower() != "N":
    print("Operation cancelled.")
if comfirm.lower() == "yes" or comfirm.lower() == "Y":
    if sign == "+" or sign == "add"  :
        print("The sum is:", a + b)
    elif sign == "-" or sign == "subtract":
        print("The difference is:", a - b)
    elif sign == "*" or sign == "multiply":
        print("The product is:", a * b)
    elif sign == "/" or sign == "divide":
        if b != 0:
            print("The quotient is:", a / b)
        else:
            print("Error: Divide by zero error.")
    elif sign == "^" or sign == "power":
        print(f"The result of {a} to the power of {b} is:", a ** b)
    else:   print("Error: Invalid operation.")
